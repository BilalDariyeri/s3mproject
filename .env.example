POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=nac_db

# FreeRADIUS clients.conf icin paylasilan gizli anahtar
RADIUS_SECRET=your_radius_secret

# Redis bağlantı bilgileri
REDIS_HOST=nac_redis
REDIS_PORT=6379
REDIS_DB=0

# Rate-limiting (başarısız giriş denemesi)
FAIL_LIMIT=3
FAIL_BLOCK_SECONDS=30
